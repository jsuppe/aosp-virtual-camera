# file_contexts for Virtual Camera
#
# Add to: device/<vendor>/<device>/sepolicy/vendor/file_contexts

# HAL binary
/vendor/bin/hw/android\.hardware\.camera\.provider-virtual-service    u:object_r:hal_camera_virtual_exec:s0

# Unix socket for renderer communication
/dev/socket/virtual_camera                                            u:object_r:virtual_camera_socket:s0
